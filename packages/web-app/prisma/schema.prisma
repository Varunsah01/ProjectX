generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  TECHNICIAN
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_REPAIR
}

enum ContractType {
  AMC
  WARRANTY
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  EXPIRING_SOON
  RENEWED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

enum InvoiceType {
  RECURRING
  ONE_TIME
  SERVICE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
  REOPENED
}

enum JobType {
  COMPLAINT
  SCHEDULED
  INSTALLATION
  INSPECTION
}

enum JobStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Organization {
  id                   String           @id @default(uuid()) @db.Uuid
  name                 String
  slug                 String           @unique
  logo                 String?
  phone                String
  email                String
  address              String
  city                 String
  gstin                String?
  placeOfBusinessState String?          @map("place_of_business_state")
  legalName            String?          @map("legal_name")
  signatureUrl         String?          @map("signature_url")
  pan                  String?
  bankName             String?          @map("bank_name")
  bankAccountNumber    String?          @map("bank_account_number")
  bankIfsc             String?          @map("bank_ifsc")
  bankBranch           String?          @map("bank_branch")
  upiId                String?          @map("upi_id")
  invoiceTerms         String?          @map("invoice_terms")
  notificationSettings Json?            @default("{}") @map("notification_settings")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  users           User[]
  customers       Customer[]
  assets          Asset[]
  contracts       Contract[]
  plans           Plan[]
  invoices        Invoice[]
  invoiceItems    InvoiceItem[]
  tickets         Ticket[]
  ticketTimelines TicketTimeline[]
  jobs            Job[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  customerNotes   CustomerNote[]

  @@map("organizations")
  @@index([createdAt])
}

model User {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @db.Uuid @map("organization_id")
  name               String
  email              String           @unique
  emailVerified      DateTime?        @map("email_verified")
  passwordHash       String           @map("password_hash")
  role               UserRole
  status             String
  avatar             String?
  image              String?
  phone              String?
  territory          String?
  specialization     String?
  skills             String[]         @default([])
  activeJobs         Int              @default(0) @map("active_jobs")
  completedToday     Int              @default(0) @map("completed_today")
  rating             Float            @default(0)
  totalJobs          Int              @default(0) @map("total_jobs")
  avgRating          Float            @default(0) @map("avg_rating")
  completedThisWeek  Int              @default(0) @map("completed_this_week")
  completedThisMonth Int              @default(0) @map("completed_this_month")
  tokenVersion       Int              @default(0) @map("token_version")
  lastActiveAt       DateTime?        @map("last_active_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts           Account[]
  sessions           Session[]
  assignedTickets    Ticket[]         @relation("TicketAssignee")
  ticketTimeline     TicketTimeline[] @relation("TicketTimelineActor")
  jobs               Job[]            @relation("JobTechnician")
  notifications      Notification[]
  auditLogs          AuditLog[]
  customerNotes      CustomerNote[]
  initiatedRefunds   Refund[]         @relation("RefundInitiator")
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  @@map("users")
  @@index([organizationId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Account {
  userId            String @db.Uuid @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int? @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
  @@index([userId])
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @db.Uuid @map("user_id")
  expires      DateTime
  csrfToken    String?  @map("csrf_token")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model Lead {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String
  company   String
  message   String?
  source    String     @default("book-demo")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("leads")
  @@index([status, createdAt(sort: Desc)])
}

model OtpChallenge {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_challenges")
  @@unique([phone, expiresAt])
  @@index([phone, createdAt(sort: Desc)])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  selector  String    @unique
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  selector  String    @unique
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
  @@index([userId])
  @@index([expiresAt])
}

model Customer {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid @map("organization_id")
  name           String
  phone          String
  email          String
  address        String
  city           String
  gstin          String?
  billingState   String?        @map("billing_state")
  shippingState  String?        @map("shipping_state")
  status         CustomerStatus
  category       String
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets         Asset[]
  contracts      Contract[]
  invoices       Invoice[]
  tickets        Ticket[]
  jobs           Job[]
  notes          CustomerNote[]

  @@map("customers")
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

model Asset {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid @map("organization_id")
  customerId       String       @db.Uuid @map("customer_id")
  name             String
  model            String
  serialNumber     String       @unique @map("serial_number")
  category         String
  installationDate DateTime     @db.Date @map("installation_date")
  warrantyEnd      DateTime     @db.Date @map("warranty_end")
  status           AssetStatus
  location         String?
  notes            String?
  amcStatus        String?      @map("amc_status")
  lastServiceDate  DateTime?    @db.Date @map("last_service_date")
  nextServiceDate  DateTime?    @db.Date @map("next_service_date")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer         Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contracts        Contract[]
  tickets          Ticket[]
  jobs             Job[]

  @@map("assets")
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model Contract {
  id              String         @id @default(uuid()) @db.Uuid
  organizationId  String         @db.Uuid @map("organization_id")
  contractNumber  String         @unique @map("contract_number")
  customerId      String         @db.Uuid @map("customer_id")
  assetId         String         @db.Uuid @map("asset_id")
  planId          String         @db.Uuid @map("plan_id")
  type            ContractType
  billingCycle    BillingCycle   @default(YEARLY) @map("billing_cycle")
  startDate       DateTime       @db.Date @map("start_date")
  endDate         DateTime       @db.Date @map("end_date")
  nextBillingDate DateTime       @default(now()) @db.Date @map("next_billing_date")
  lastBilledDate  DateTime?      @db.Date @map("last_billed_date")
  status          ContractStatus
  value           Int
  visitsCovered   Int            @map("visits_covered")
  visitsUsed      Int            @default(0) @map("visits_used")
  nextServiceDate DateTime?      @db.Date @map("next_service_date")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  asset           Asset          @relation(fields: [assetId], references: [id])
  plan            Plan           @relation(fields: [planId], references: [id])
  invoices        Invoice[]

  @@map("contracts")
  @@index([organizationId])
  @@index([organizationId, nextBillingDate])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model Plan {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid @map("organization_id")
  name           String
  type           ContractType
  durationMonths Int            @map("duration_months")
  price          Int
  visitsCovered  Int            @map("visits_covered")
  description    String
  hsnSac         String         @map("hsn_sac")
  gstRatePercent Decimal        @db.Decimal(5, 2) @map("gst_rate_percent")
  gstApplicable  Boolean        @default(true) @map("gst_applicable")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts      Contract[]

  @@map("plans")
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([createdAt])
}

model Invoice {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid @map("organization_id")
  invoiceNumber  String         @unique @map("invoice_number")
  customerId     String         @db.Uuid @map("customer_id")
  contractId     String?        @db.Uuid @map("contract_id")
  amount         Int
  paidAmount     Int            @default(0) @map("paid_amount")
  placeOfSupply  String?        @map("place_of_supply")
  isInterState   Boolean?       @map("is_inter_state")
  subtotalAmount Int?           @map("subtotal_amount")
  cgstAmount     Int?           @map("cgst_amount")
  sgstAmount     Int?           @map("sgst_amount")
  igstAmount     Int?           @map("igst_amount")
  totalTaxAmount Int?           @map("total_tax_amount")
  dueDate        DateTime       @db.Date @map("due_date")
  issuedDate     DateTime       @db.Date @map("issued_date")
  status         InvoiceStatus
  type           InvoiceType
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contract       Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items          InvoiceItem[]
  payments       Payment[]

  @@map("invoices")
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model InvoiceItem {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid @map("organization_id")
  invoiceId      String       @db.Uuid @map("invoice_id")
  description    String
  qty            Int
  rate           Int
  amount         Int
  hsnSac         String?      @map("hsn_sac")
  gstRatePercent Decimal?     @db.Decimal(5, 2) @map("gst_rate_percent")
  taxableAmount  Int?         @map("taxable_amount")
  cgstAmount     Int?         @map("cgst_amount")
  sgstAmount     Int?         @map("sgst_amount")
  igstAmount     Int?         @map("igst_amount")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
  @@index([organizationId])
  @@index([invoiceId])
}

model Payment {
  id                    String   @id @default(uuid()) @db.Uuid
  invoiceId             String   @db.Uuid @map("invoice_id")
  razorpayOrderId       String   @unique @map("razorpay_order_id")
  razorpayPaymentId     String?  @unique @map("razorpay_payment_id")
  amount                Int
  refundedAmountPaisa   Int      @default(0) @map("refunded_amount_paisa")
  status                String
  method                String   @default("razorpay")
  createdAt             DateTime @default(now()) @map("created_at")
  invoice               Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  refunds               Refund[]

  @@map("payments")
  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
}

model Refund {
  id                String       @id @default(uuid()) @db.Uuid
  paymentId         String       @db.Uuid @map("payment_id")
  razorpayRefundId  String?      @unique @map("razorpay_refund_id")
  amountPaisa       Int          @map("amount_paisa")
  reason            String
  status            RefundStatus @default(PENDING)
  notes             Json         @default("{}")
  initiatedById     String       @db.Uuid @map("initiated_by_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  processedAt       DateTime?    @map("processed_at")
  payment           Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  initiatedBy       User         @relation("RefundInitiator", fields: [initiatedById], references: [id])

  @@map("refunds")
  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
}

model WebhookEvent {
  id          String             @id @default(uuid()) @db.Uuid
  provider    String
  eventId     String             @unique @map("event_id")
  eventType   String             @map("event_type")
  payload     Json
  receivedAt  DateTime           @default(now()) @map("received_at")
  processedAt DateTime?          @map("processed_at")
  status      WebhookEventStatus @default(RECEIVED)
  error       String?

  @@map("webhook_events")
  @@index([provider, eventType, receivedAt(sort: Desc)])
  @@index([status])
  @@index([receivedAt(sort: Desc)])
}

model Ticket {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid @map("organization_id")
  ticketNumber   String         @unique @map("ticket_number")
  customerId     String         @db.Uuid @map("customer_id")
  assetId        String?        @db.Uuid @map("asset_id")
  subject        String
  description    String
  category       String
  priority       TicketPriority
  status         TicketStatus
  assignedToId   String?        @db.Uuid @map("assigned_to_id")
  slaDeadline    DateTime       @map("sla_deadline")
  resolvedAt     DateTime?      @map("resolved_at")
  proofKeys      String[]       @default([]) @map("proof_keys")
  proofMetadata  Json           @default("[]") @map("proof_metadata")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  asset          Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignedTo     User?          @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  timeline       TicketTimeline[]
  jobs           Job[]

  @@map("tickets")
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model TicketTimeline {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid @map("organization_id")
  ticketId       String       @db.Uuid @map("ticket_id")
  byUserId       String       @db.Uuid @map("by_user_id")
  action         String
  note           String?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  byUser         User         @relation("TicketTimelineActor", fields: [byUserId], references: [id])

  @@map("ticket_timelines")
  @@index([organizationId])
  @@index([ticketId])
  @@index([createdAt])
}

model Job {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid @map("organization_id")
  jobNumber      String       @unique @map("job_number")
  ticketId       String?      @db.Uuid @map("ticket_id")
  customerId     String       @db.Uuid @map("customer_id")
  assetId        String?      @db.Uuid @map("asset_id")
  technicianId   String       @db.Uuid @map("technician_id")
  type           JobType
  status         JobStatus
  scheduledDate  DateTime     @db.Date @map("scheduled_date")
  completedAt    DateTime?    @map("completed_at")
  notes          String?
  serviceReport  String?      @map("service_report")
  proofKeys      String[]     @default([]) @map("proof_keys")
  proofMetadata  Json         @default("[]") @map("proof_metadata")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket         Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  asset          Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  technician     User         @relation("JobTechnician", fields: [technicianId], references: [id])

  @@map("jobs")
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledDate])
  @@index([createdAt])
}

model Notification {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid @map("organization_id")
  userId         String       @db.Uuid @map("user_id")
  type           String
  title          String
  message        String
  read           Boolean      @default(false) @map("is_read")
  link           String?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid @map("organization_id")
  userId         String       @db.Uuid @map("user_id")
  action         String
  entity         String
  entityId       String       @map("entity_id")
  changes        Json
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([organizationId])
  @@index([createdAt])
}

model CustomerNote {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid @map("organization_id")
  customerId     String       @db.Uuid @map("customer_id")
  userId         String       @db.Uuid @map("user_id")
  type           String
  note           String
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@map("customer_notes")
  @@index([organizationId])
  @@index([customerId])
  @@index([createdAt])
}
