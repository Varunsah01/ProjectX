// ─── DPDPA Compliance Models ─────────────────────────────────────────────────

model Consent {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  dataPrincipalId   String            @map("data_principal_id") @db.Uuid
  dataPrincipalType DataPrincipalType @map("data_principal_type")
  purpose           ConsentPurpose
  status            ConsentStatus     @default(WITHDRAWN)
  grantedAt         DateTime?         @map("granted_at")
  withdrawnAt       DateTime?         @map("withdrawn_at")
  legalBasis        String            @map("legal_basis")
  evidence          Json              @default("{}")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, dataPrincipalId, dataPrincipalType, purpose])
  @@index([organizationId, dataPrincipalId, dataPrincipalType])
  @@index([organizationId, status])
  @@index([createdAt])
  @@map("consents")
}

model BreachLog {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @map("organization_id") @db.Uuid
  detectedAt             DateTime     @map("detected_at")
  scope                  String       @db.Text
  affectedPrincipals     Int          @default(0) @map("affected_principals")
  status                 BreachStatus @default(DETECTED)
  reportedToBoardAt      DateTime?    @map("reported_to_board_at")
  reportedToPrincipalsAt DateTime?    @map("reported_to_principals_at")
  notes                  String?      @db.Text
  createdById            String       @map("created_by_id") @db.Uuid
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy              User         @relation("BreachLogCreator", fields: [createdById], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, detectedAt(sort: Desc)])
  @@index([createdAt])
  @@map("breach_logs")
}

model DsrRequest {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  dataPrincipalId   String            @map("data_principal_id") @db.Uuid
  dataPrincipalType DataPrincipalType @map("data_principal_type")
  type              DsrType
  status            DsrStatus         @default(PENDING)
  details           Json              @default("{}")
  responseNotes     String?           @map("response_notes") @db.Text
  processedById     String?           @map("processed_by_id") @db.Uuid
  processedAt       DateTime?         @map("processed_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  processedBy       User?             @relation("DsrProcessedBy", fields: [processedById], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, dataPrincipalId, dataPrincipalType])
  @@index([createdAt])
  @@map("dsr_requests")
}

