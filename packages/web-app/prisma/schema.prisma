generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  TECHNICIAN
  SUPPORT
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_REPAIR
}

enum ContractType {
  AMC
  WARRANTY
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  EXPIRING_SOON
  RENEWED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

enum InvoiceType {
  RECURRING
  ONE_TIME
  SERVICE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
  REOPENED
}

enum JobType {
  COMPLAINT
  SCHEDULED
  INSTALLATION
  INSPECTION
}

enum JobStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ImportKind {
  CUSTOMERS
  ASSETS
}

enum ImportStatus {
  PREVIEW
  COMMITTED
  FAILED
  EXPIRED
}

enum CronRunStatus {
  RUNNING
  DONE
  FAILED
}

enum ContractReminderStage {
  T_30
  T_7
  T_1
}

enum InvoiceReminderStage {
  D_3
  D_7
  D_15
}

enum PreferredChannel {
  EMAIL
  SMS
  WHATSAPP
}

// ─── DPDPA Compliance Enums ──────────────────────────────────────────────────

enum DataPrincipalType {
  USER
  CUSTOMER
}

enum ConsentPurpose {
  SERVICE_DELIVERY
  COMMUNICATION
  ANALYTICS
  MARKETING
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
}

enum BreachStatus {
  DETECTED
  REPORTED
  CLOSED
}

enum DsrType {
  ACCESS
  CORRECTION
  ERASURE
}

enum DsrStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model Organization {
  id                   String           @id @default(uuid()) @db.Uuid
  name                 String
  slug                 String           @unique
  logo                 String?
  phone                String
  email                String
  address              String
  city                 String
  gstin                String?
  placeOfBusinessState String?          @map("place_of_business_state")
  legalName            String?          @map("legal_name")
  signatureUrl         String?          @map("signature_url")
  pan                  String?
  bankName             String?          @map("bank_name")
  bankAccountNumber    String?          @map("bank_account_number")
  bankIfsc             String?          @map("bank_ifsc")
  bankBranch           String?          @map("bank_branch")
  upiId                String?          @map("upi_id")
  invoiceTerms         String?          @map("invoice_terms")
  notificationSettings  Json?            @default("{}") @map("notification_settings")
  grievanceOfficerName  String?          @map("grievance_officer_name")
  grievanceOfficerEmail String?          @map("grievance_officer_email")
  grievanceOfficerPhone String?          @map("grievance_officer_phone")
  accountantEmail       String?          @map("accountant_email")
  exportFormat          String?          @map("export_format")
  lastExportSentAt      DateTime?        @map("last_export_sent_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  users                 User[]
  customers             Customer[]
  assets                Asset[]
  contracts             Contract[]
  plans                 Plan[]
  invoices              Invoice[]
  invoiceItems          InvoiceItem[]
  tickets               Ticket[]
  ticketTimelines       TicketTimeline[]
  jobs                  Job[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  customerNotes         CustomerNote[]
  importJobs            ImportJob[]
  messageLogs           MessageLog[]
  memberships           OrgMembership[]
  invitations           OrgInvitation[]
  consents              Consent[]
  breachLogs            BreachLog[]
  dsrRequests           DsrRequest[]

  @@index([createdAt])
  @@map("organizations")
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  organizationId          String?                  @map("organization_id") @db.Uuid
  name                    String
  email                   String                   @unique
  emailVerified           DateTime?                @map("email_verified")
  passwordHash            String                   @map("password_hash")
  role                    UserRole?
  status                  String
  avatar                  String?
  image                   String?
  phone                   String?
  territory               String?
  specialization          String?
  skills                  String[]                 @default([])
  activeJobs              Int                      @default(0) @map("active_jobs")
  completedToday          Int                      @default(0) @map("completed_today")
  rating                  Float                    @default(0)
  totalJobs               Int                      @default(0) @map("total_jobs")
  avgRating               Float                    @default(0) @map("avg_rating")
  completedThisWeek       Int                      @default(0) @map("completed_this_week")
  completedThisMonth      Int                      @default(0) @map("completed_this_month")
  tokenVersion            Int                      @default(0) @map("token_version")
  lastActiveAt            DateTime?                @map("last_active_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  organization            Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts                Account[]
  memberships             OrgMembership[]
  sentInvitations         OrgInvitation[]          @relation("InvitationSender")
  sessions                Session[]
  assignedTickets         Ticket[]                 @relation("TicketAssignee")
  ticketTimeline          TicketTimeline[]         @relation("TicketTimelineActor")
  jobs                    Job[]                    @relation("JobTechnician")
  notifications           Notification[]
  auditLogs               AuditLog[]
  customerNotes           CustomerNote[]
  initiatedRefunds        Refund[]                 @relation("RefundInitiator")
  deviceTokens            DeviceToken[]
  importJobs              ImportJob[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  createdBreachLogs       BreachLog[]              @relation("BreachLogCreator")
  processedDsrs           DsrRequest[]             @relation("DsrProcessedBy")
  impersonationsSent      ImpersonationSession[]   @relation("SupportImpersonations")
  impersonationsReceived  ImpersonationSession[]   @relation("TargetImpersonations")
  actedAuditLogs          AuditLog[]               @relation("ImpersonationAuditLogs")

  @@index([organizationId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Account {
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  csrfToken    String?  @map("csrf_token")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model Lead {
  id               String     @id @default(uuid()) @db.Uuid
  name             String
  email            String
  phone            String?
  company          String
  role             String?
  companySize      String?    @map("company_size")
  industry         String?
  preferredContact String?    @map("preferred_contact")
  message          String?
  source           String     @default("book-demo")
  status           LeadStatus @default(NEW)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@map("leads")
}

model OtpChallenge {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([phone, expiresAt])
  @@index([phone, createdAt(sort: Desc)])
  @@map("otp_challenges")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  selector  String    @unique
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  selector  String    @unique
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model Customer {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @map("organization_id") @db.Uuid
  name             String
  phone            String
  email            String
  address          String
  city             String
  gstin            String?
  billingState     String?             @map("billing_state")
  shippingState    String?             @map("shipping_state")
  status           CustomerStatus
  category         String
  preferredChannel PreferredChannel    @default(EMAIL) @map("preferred_channel")
  whatsappOptOut   Boolean             @default(false) @map("whatsapp_opt_out")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  deletedAt        DateTime?           @map("deleted_at")
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets           Asset[]
  contracts        Contract[]
  invoices         Invoice[]
  tickets          Ticket[]
  jobs             Job[]
  notes            CustomerNote[]
  messageLogs      MessageLog[]
  magicLinks       CustomerMagicLink[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([status])
  @@index([createdAt])
  @@map("customers")
}

model Asset {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  customerId       String       @map("customer_id") @db.Uuid
  name             String
  model            String
  serialNumber     String       @unique @map("serial_number")
  category         String
  installationDate DateTime     @map("installation_date") @db.Date
  warrantyEnd      DateTime     @map("warranty_end") @db.Date
  status           AssetStatus
  location         String?
  notes            String?
  amcStatus        String?      @map("amc_status")
  lastServiceDate  DateTime?    @map("last_service_date") @db.Date
  nextServiceDate  DateTime?    @map("next_service_date") @db.Date
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer         Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contracts        Contract[]
  tickets          Ticket[]
  jobs             Job[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("assets")
}

model Contract {
  id              String             @id @default(uuid()) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  contractNumber  String             @unique @map("contract_number")
  customerId      String             @map("customer_id") @db.Uuid
  assetId         String             @map("asset_id") @db.Uuid
  planId          String             @map("plan_id") @db.Uuid
  type            ContractType
  billingCycle    BillingCycle       @default(YEARLY) @map("billing_cycle")
  startDate       DateTime           @map("start_date") @db.Date
  endDate         DateTime           @map("end_date") @db.Date
  nextBillingDate DateTime           @default(now()) @map("next_billing_date") @db.Date
  lastBilledDate  DateTime?          @map("last_billed_date") @db.Date
  status          ContractStatus
  value           Int
  visitsCovered   Int                @map("visits_covered")
  visitsUsed      Int                @default(0) @map("visits_used")
  nextServiceDate DateTime?          @map("next_service_date") @db.Date
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  asset           Asset              @relation(fields: [assetId], references: [id])
  plan            Plan               @relation(fields: [planId], references: [id])
  invoices        Invoice[]
  reminders       ContractReminder[]

  @@index([organizationId])
  @@index([organizationId, nextBillingDate])
  @@index([organizationId, deletedAt])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("contracts")
}

model Plan {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  type           ContractType
  durationMonths Int          @map("duration_months")
  price          Int
  visitsCovered  Int          @map("visits_covered")
  description    String
  hsnSac         String       @map("hsn_sac")
  gstRatePercent Decimal      @map("gst_rate_percent") @db.Decimal(5, 2)
  gstApplicable  Boolean      @default(true) @map("gst_applicable")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts      Contract[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([createdAt])
  @@map("plans")
}

model Invoice {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  invoiceNumber  String            @unique @map("invoice_number")
  customerId     String            @map("customer_id") @db.Uuid
  contractId     String?           @map("contract_id") @db.Uuid
  amount         Int
  paidAmount     Int               @default(0) @map("paid_amount")
  placeOfSupply  String?           @map("place_of_supply")
  isInterState   Boolean?          @map("is_inter_state")
  subtotalAmount Int?              @map("subtotal_amount")
  cgstAmount     Int?              @map("cgst_amount")
  sgstAmount     Int?              @map("sgst_amount")
  igstAmount     Int?              @map("igst_amount")
  totalTaxAmount Int?              @map("total_tax_amount")
  dueDate        DateTime          @map("due_date") @db.Date
  issuedDate     DateTime          @map("issued_date") @db.Date
  status         InvoiceStatus
  type           InvoiceType
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contract       Contract?         @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items          InvoiceItem[]
  payments       Payment[]
  reminders      InvoiceReminder[]

  @@index([organizationId, status, dueDate])
  @@index([organizationId, customerId, createdAt(sort: Desc)])
  @@index([organizationId, deletedAt])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  invoiceId      String       @map("invoice_id") @db.Uuid
  description    String
  qty            Int
  rate           Int
  amount         Int
  hsnSac         String?      @map("hsn_sac")
  gstRatePercent Decimal?     @map("gst_rate_percent") @db.Decimal(5, 2)
  taxableAmount  Int?         @map("taxable_amount")
  cgstAmount     Int?         @map("cgst_amount")
  sgstAmount     Int?         @map("sgst_amount")
  igstAmount     Int?         @map("igst_amount")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id                  String   @id @default(uuid()) @db.Uuid
  invoiceId           String   @map("invoice_id") @db.Uuid
  razorpayOrderId     String   @unique @map("razorpay_order_id")
  razorpayPaymentId   String?  @unique @map("razorpay_payment_id")
  amount              Int
  refundedAmountPaisa Int      @default(0) @map("refunded_amount_paisa")
  status              String
  method              String   @default("razorpay")
  createdAt           DateTime @default(now()) @map("created_at")
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  refunds             Refund[]

  @@index([invoiceId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Refund {
  id               String       @id @default(uuid()) @db.Uuid
  paymentId        String       @map("payment_id") @db.Uuid
  razorpayRefundId String?      @unique @map("razorpay_refund_id")
  amountPaisa      Int          @map("amount_paisa")
  reason           String
  status           RefundStatus @default(PENDING)
  notes            Json         @default("{}")
  initiatedById    String       @map("initiated_by_id") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")
  processedAt      DateTime?    @map("processed_at")
  payment          Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  initiatedBy      User         @relation("RefundInitiator", fields: [initiatedById], references: [id])

  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
  @@map("refunds")
}

model WebhookEvent {
  id          String             @id @default(uuid()) @db.Uuid
  provider    String
  eventId     String             @unique @map("event_id")
  eventType   String             @map("event_type")
  payload     Json
  receivedAt  DateTime           @default(now()) @map("received_at")
  processedAt DateTime?          @map("processed_at")
  status      WebhookEventStatus @default(RECEIVED)
  error       String?

  @@index([provider, eventType, receivedAt(sort: Desc)])
  @@index([status])
  @@index([receivedAt(sort: Desc)])
  @@map("webhook_events")
}

model Ticket {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  ticketNumber   String           @unique @map("ticket_number")
  customerId     String           @map("customer_id") @db.Uuid
  assetId        String?          @map("asset_id") @db.Uuid
  subject        String
  description    String
  category       String
  priority       TicketPriority
  status         TicketStatus
  assignedToId   String?          @map("assigned_to_id") @db.Uuid
  slaDeadline    DateTime         @map("sla_deadline")
  resolvedAt     DateTime?        @map("resolved_at")
  proofKeys      String[]         @default([]) @map("proof_keys")
  proofMetadata  Json             @default("[]") @map("proof_metadata")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  asset          Asset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assignedTo     User?            @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  timeline       TicketTimeline[]
  jobs           Job[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, deletedAt])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("tickets")
}

model TicketTimeline {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  ticketId       String       @map("ticket_id") @db.Uuid
  byUserId       String?      @map("by_user_id") @db.Uuid
  action         String
  note           String?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  byUser         User?        @relation("TicketTimelineActor", fields: [byUserId], references: [id])

  @@index([organizationId])
  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_timelines")
}

model Job {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  jobNumber      String       @unique @map("job_number")
  ticketId       String?      @map("ticket_id") @db.Uuid
  customerId     String       @map("customer_id") @db.Uuid
  assetId        String?      @map("asset_id") @db.Uuid
  technicianId   String       @map("technician_id") @db.Uuid
  type           JobType
  status         JobStatus
  scheduledDate  DateTime     @map("scheduled_date") @db.Date
  completedAt    DateTime?    @map("completed_at")
  notes          String?
  serviceReport  String?      @map("service_report")
  proofKeys      String[]     @default([]) @map("proof_keys")
  proofMetadata  Json         @default("[]") @map("proof_metadata")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket         Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  asset          Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  technician     User         @relation("JobTechnician", fields: [technicianId], references: [id])

  @@index([organizationId, technicianId, status, scheduledDate])
  @@index([organizationId, customerId, createdAt(sort: Desc)])
  @@index([organizationId, deletedAt])
  @@index([status])
  @@index([scheduledDate])
  @@index([createdAt])
  @@map("jobs")
}

model Notification {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  type           String
  title          String
  message        String
  read           Boolean      @default(false) @map("is_read")
  link           String?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
