DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_x?schema=public"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3001/api/auth/callback/google (dev)
#                          https://app.recuring.in/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack incoming webhook URL for support impersonation audit alerts
SUPPORT_AUDIT_CHANNEL_WEBHOOK=
CRON_SECRET=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASSWORD=smtp-password
FROM_EMAIL=Recuring <no-reply@example.com>
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Cloudflare R2 storage (S3-compatible)
# Get these from the Cloudflare dashboard under R2 > Manage API Tokens
CLOUDFLARE_R2_ENDPOINT=https://.r2.cloudflarestorage.com
S3_BUCKET=your-r2-bucket-name
S3_REGION=auto
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Health / Status
STATUS_TOKEN=

# ─── Customer Messaging ────────────────────────────────────────────────────────
MESSAGING_PROVIDER=console          # console | msg91 | gupshup

# MSG91 SMS (DLT-approved template IDs — must match TRAI DLT registration)
MSG91_SMS_SENDER_ID=YOURID
MSG91_SMS_DLT_INVOICE_ISSUED=
MSG91_SMS_DLT_PAYMENT_RECEIVED=
MSG91_SMS_DLT_TECHNICIAN_EN_ROUTE=
MSG91_SMS_DLT_JOB_COMPLETED=
MSG91_SMS_DLT_CONTRACT_RENEWAL_DUE=

# MSG91 WhatsApp (approved template names)
MSG91_WA_INTEGRATED_NUMBER=
MSG91_WA_TEMPLATE_INVOICE_ISSUED=
MSG91_WA_TEMPLATE_PAYMENT_RECEIVED=
MSG91_WA_TEMPLATE_TECHNICIAN_EN_ROUTE=
MSG91_WA_TEMPLATE_JOB_COMPLETED=
MSG91_WA_TEMPLATE_CONTRACT_RENEWAL_DUE=

# Gupshup WhatsApp
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_WA_TEMPLATE_INVOICE_ISSUED=
GUPSHUP_WA_TEMPLATE_PAYMENT_RECEIVED=
GUPSHUP_WA_TEMPLATE_TECHNICIAN_EN_ROUTE=
GUPSHUP_WA_TEMPLATE_JOB_COMPLETED=
GUPSHUP_WA_TEMPLATE_CONTRACT_RENEWAL_DUE=

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Neon Branch API (backup verification) ───────────────────────────────────
# Get from: console.neon.tech → Project Settings → API Keys
NEON_API_KEY=
NEON_PROJECT_ID=

# ─── Ops Alerts ───────────────────────────────────────────────────────────────
# Slack incoming webhook for infrastructure/ops alerts (separate from support audit)
OPS_SLACK_WEBHOOK=

# ─── Docs Site ────────────────────────────────────────────────────────────────
# URL of the hosted Nextra docs site (used for in-app "?" help links)
NEXT_PUBLIC_DOCS_URL=https://docs.recuring.in

# ─── Feature Flags (GrowthBook) ───────────────────────────────────────────────
# Get your client key from app.growthbook.io → SDK Connections → Add Connection
# This key is public — safe to commit and expose to the browser.
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-
# Override if self-hosting GrowthBook (see docs/feature-flags.md)
NEXT_PUBLIC_GROWTHBOOK_API_HOST=https://cdn.growthbook.io
