DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_x?schema=public"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
CRON_SECRET=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASSWORD=smtp-password
FROM_EMAIL=Recuring <no-reply@example.com>
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Cloudflare R2 storage (S3-compatible)
# Get these from the Cloudflare dashboard under R2 > Manage API Tokens
CLOUDFLARE_R2_ENDPOINT=https://.r2.cloudflarestorage.com
S3_BUCKET=your-r2-bucket-name
S3_REGION=auto
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
