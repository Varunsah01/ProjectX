    "@types/swagger-ui-react": "^4.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
