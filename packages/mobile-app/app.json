{
  "expo": {
    "name": "Field Operator",
    "slug": "field-operator",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "microphonePermission": false
        }
      ]
    ],
    "platforms": ["android"],
    "android": {
      "package": "com.projectx.fieldoperator",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F766E"
      }
    }
  }
}
