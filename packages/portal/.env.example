# Database (shared with web-app)
DATABASE_URL="postgresql://user:pass@localhost:5432/recuring?schema=public"

# Auth
PORTAL_AUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3002"

# Subdomain (dev only — bypass subdomain resolution)
PORTAL_DEV_ORG_SLUG="demo"

# Email (shared with web-app)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
FROM_EMAIL="noreply@recuring.in"

# Razorpay (shared with web-app)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Object Storage / R2 (shared with web-app)
S3_BUCKET=""
S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Cookie domain (production only)
# PORTAL_COOKIE_DOMAIN=".portal.recuring.in"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Portal URL (used in magic-link emails)
NEXT_PUBLIC_PORTAL_URL="http://localhost:3002"
