# Recuring web app environment template
#
# Copy this file to `.env.local` at the repo root:
#   cp .env.example.local .env.local
#
# How this monorepo reads env vars:
# - `npm run dev:web` and `npm run build:web` at the repo root source the repo-root `.env.local`
# - If you run commands inside `packages/web-app` directly, mirror the same values into
#   `packages/web-app/.env.local` or export them in your shell first
#
# Where to also set these for deployment:
# - Vercel Dashboard -> Project -> Settings -> Environment Variables
# - Add each variable to the environments you use: Production, Preview, Development
# - After changing a Vercel env var, redeploy so the new value reaches the next deployment
# - Optional CLI sync: `vercel env pull .env.local`
#
# Important local-file note:
# - This repo sources `.env.local` in `zsh`, so values with `&` query params or spaces should stay
#   wrapped in double quotes here
# - In Vercel, paste the raw value without the surrounding quotes
#
# Official docs used for the setup notes below:
# - Neon connect: https://neon.com/docs/get-started-with-neon/connect-neon
# - Neon pooling: https://neon.com/docs/connect/connection-pooling
# - Vercel env vars: https://vercel.com/docs/projects/environment-variables
# - Vercel cron security: https://vercel.com/docs/cron-jobs/manage-cron-jobs
# - Razorpay API keys: https://razorpay.com/docs/payments/dashboard/account-settings/api-keys/
# - Razorpay webhooks: https://razorpay.com/docs/payments/dashboard/account-settings/webhooks/

# Required core database config

# Neon pooled runtime connection used by the app.
# Code path: packages/web-app/prisma/schema.prisma -> datasource `url`
# How to get it:
# 1. Create or sign in to a Neon account at https://console.neon.tech/
# 2. Create a project, database, and role/user
# 3. Open the project, click Connect, choose the branch/database/role, and copy the pooled URL
# 4. Keep the pooled host (`-pooler` in the hostname) for DATABASE_URL
# Also set on Vercel: DATABASE_URL for every environment where the app runs
DATABASE_URL="postgresql://db_user:db_password@ep-example-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true"

# Neon direct connection used only for Prisma migrations.
# Code path: packages/web-app/prisma/schema.prisma -> datasource `directUrl`
# How to get it:
# 1. In the same Neon Connect modal, copy the direct or non-pooled connection string
# 2. Use the host without `-pooler`
# 3. Do not append `pgbouncer=true` to DIRECT_URL
# Also set wherever migrations run:
# - Local machine or CI secret store
# - Vercel too, only if you plan to run Prisma migrations from Vercel
DIRECT_URL="postgresql://db_user:db_password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Required authentication and app URL config

# Auth.js / NextAuth signing secret.
# Code path: packages/web-app/auth.config.ts
# How to create it:
# - Run `openssl rand -base64 32`
# - Use a different strong value for production if needed
# Also set on Vercel: NEXTAUTH_SECRET in Production, Preview, and Development
# This repo also accepts AUTH_SECRET as a fallback, but NEXTAUTH_SECRET alone is enough here
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Canonical URL used by Auth.js callbacks.
# Local: keep http://localhost:3001
# Vercel Production: set this to your primary domain, for example https://app.example.com
# Vercel Preview: set if you need auth flows to work on preview deployments too
NEXTAUTH_URL=http://localhost:3001

# Public app URL used in email templates and frontend-visible links.
# Code path: packages/web-app/lib/email-templates/_shared.tsx
# Keep this equal to the user-facing URL for each environment
# Also set on Vercel anywhere you deploy the web app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Shared secret for the protected recurring-invoice cron endpoint.
# Code paths:
# - packages/web-app/app/api/cron/generate-invoices/route.ts
# - vercel.json
# How to create it:
# - Run `openssl rand -base64 32`
# Vercel note:
# - When CRON_SECRET is set in Vercel, Vercel sends `Authorization: Bearer <CRON_SECRET>`
#   to scheduled cron requests automatically
# Also set on Vercel: Production at minimum, plus Preview/Development if you test the cron route there
CRON_SECRET=replace-with-a-long-random-secret

# Optional email delivery config

# Email address that receives new demo requests submitted via the landing page /book-demo form.
# Code path: packages/landing/app/api/demo-request/route.ts
# Falls back to SMTP_USER if not set. Set this to whoever should be notified about new leads.
DEMO_NOTIFY_EMAIL=your-email@example.com

# SMTP host from your mail provider.
# Code path: packages/web-app/lib/email.ts, packages/landing/lib/email.ts
# How to get it:
# 1. Sign up with an SMTP-capable provider or use your company mail server
# 2. In that provider's dashboard, find the SMTP host, port, username, password, and verified sender
# 3. Put the same values here and in Vercel for any environment that should send mail
# If SMTP is not configured, the code skips sending email instead of crashing
SMTP_HOST=smtp.example.com

# SMTP port from your provider. Common values are 587 (STARTTLS) or 465 (implicit TLS).
SMTP_PORT=587

# SMTP username from your provider dashboard.
SMTP_USER=smtp-user

# SMTP password or app password from your provider dashboard.
SMTP_PASSWORD=smtp-password

# Verified sender identity for outbound email.
# Use a sender address your provider has approved or verified
FROM_EMAIL="Recuring <no-reply@example.com>"

# Optional Razorpay payment config

# Razorpay key id used when creating payment orders.
# Code paths:
# - packages/web-app/lib/razorpay.ts
# - packages/web-app/app/api/payments/create-order/route.ts
# How to get it:
# 1. Create or sign in to your account at https://dashboard.razorpay.com/
# 2. For testing, stay in Test Mode; for production, complete live onboarding/KYC first
# 3. Open Account & Settings -> API Keys -> Generate Key
# Also set on Vercel anywhere payments are enabled
RAZORPAY_KEY_ID=

# Razorpay key secret paired with the key id above.
# Keep this server-side only and never expose it in client code
RAZORPAY_KEY_SECRET=

# Razorpay webhook secret used to validate webhook signatures.
# Code path: packages/web-app/app/api/webhooks/razorpay/route.ts
# How to get it:
# 1. In Razorpay Dashboard, open Account & Settings -> Webhooks -> Add New Webhook
# 2. Set the webhook URL to `https://your-domain.com/api/webhooks/razorpay`
# 3. Enter your own strong secret in Razorpay and paste the same value here
# 4. Use Test Mode secrets for dev/preview and Live Mode secrets only in production
# Note: this is separate from the API key secret above
RAZORPAY_WEBHOOK_SECRET=

# --- AWS S3 (REQUIRED for proof uploads) ---
# Mobile job/complaint proof uploads use presigned PUT URLs to this bucket.
# With these unset, /api/mobile/v1/uploads/sign returns 503 and the mobile UI
# surfaces "storage not configured" instead of crashing.
# Install: `npm i @aws-sdk/client-s3 @aws-sdk/s3-request-presigner` (already in
# packages/web-app). Bucket must exist with private ACL; CORS must allow PUT
# from your mobile/web origins.
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Upstash Redis (rate limiting) ---
# Used by lib/security/rate-limit.ts for sliding-window counters shared across
# instances. With these unset, the app falls back to a single-process in-memory
# limiter and logs one boot warning. Required in any multi-instance deployment.
# Setup: create a Redis database at https://console.upstash.com/, copy the REST
# URL and REST Token from the dashboard.
UPSTASH_REDIS_REST_URL=      # Upstash Redis REST URL (rate-limiting)
UPSTASH_REDIS_REST_TOKEN=    # Upstash Redis REST token

# --- Landing → web-app lead intake ---
# Shared secret the landing site uses to POST to web-app /api/leads. Set the
# SAME value on both packages. With this unset on either side, /book-demo
# falls back to its legacy SMTP-only behaviour (lead is emailed but not
# persisted).
LANDING_LEAD_TOKEN=
# Internal URL the landing site uses to reach the web-app's /api/leads route
# (server-to-server). Defaults to NEXT_PUBLIC_APP_URL when unset.
WEB_APP_INTERNAL_URL=

# --- Mobile OTP (phone login) ---
# Provider selector: "console" logs codes to the server log (dev); "msg91"
# sends real SMS. Default is "msg91" in production, "console" otherwise.
OTP_PROVIDER=console         # console | msg91 (set msg91 in production)
# MSG91 credentials (required when OTP_PROVIDER=msg91). Set up an OTP template
# in the MSG91 dashboard, then copy the auth key, template id, and sender id.
# Used by lib/otp/msg91-provider.ts
MSG91_AUTH_KEY=              # MSG91 API key (required when OTP_PROVIDER=msg91)
MSG91_TEMPLATE_ID=           # MSG91 OTP template ID
MSG91_SENDER_ID=             # MSG91 OTP sender ID (6-char DLT sender for OTP SMS)
# Used by lib/messaging/msg91-provider.ts (transactional SMS and WhatsApp)
MSG91_SMS_SENDER_ID=         # MSG91 DLT sender ID for transactional SMS (distinct from OTP sender)
MSG91_WA_INTEGRATED_NUMBER=  # MSG91 WhatsApp integrated number (required for WhatsApp channel)

# --- DPDPA Compliance (data residency) ---
# Expected database region for the data-residency runtime check.
# In production, instrumentation.ts compares DATABASE_URL's hostname against
# this value; a mismatch prevents the app from starting.
# Set to whatever region suffix your Neon/RDS host ends with (e.g. ap-south-1).
EXPECTED_DB_REGION=ap-south-1

# --- Sentry (error monitoring) ---
# DSN-gated: with these unset, no Sentry init runs and no warnings are logged.
SENTRY_DSN=                  # web-app + landing (server, edge); shared project allowed
NEXT_PUBLIC_SENTRY_DSN=      # web-app + landing (browser); same DSN, optional
EXPO_PUBLIC_SENTRY_DSN=      # Sentry DSN for mobile app (optional)

# Legacy Docker-only variables kept for reference.
# Leave these commented out when Neon is your database.
# POSTGRES_DB=recuring_dev
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# PGADMIN_DEFAULT_EMAIL=admin@local.dev
# PGADMIN_DEFAULT_PASSWORD=admin123


# ─── Feature Flags (GrowthBook) ───────────────────────────────────────────────
# Get your client key from app.growthbook.io → SDK Connections → Add Connection
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-      # web-app + portal (public key, same for both)
NEXT_PUBLIC_GROWTHBOOK_API_HOST=https://cdn.growthbook.io  # override for self-hosted
EXPO_PUBLIC_GROWTHBOOK_CLIENT_KEY=sdk-      # mobile app (can be same key as above)
