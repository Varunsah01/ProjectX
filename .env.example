# Quick start:
# cp .env.example .env.local
# npm run docker:up
# npm run db:setup
# npm run dev:web
#
# Notes:
# - The default DATABASE_URL below matches docker-compose.yml.
# - Replace placeholder secrets before using this outside local development.

# PostgreSQL connection string used by Prisma and the web app.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recuring_dev?schema=public

# Secret used by Auth.js / NextAuth to sign JWTs and cookies.
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Public URL where the web app is reachable in local development.
NEXTAUTH_URL=http://localhost:3001

# Public base URL exposed to the frontend.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Shared secret for protected cron endpoints such as recurring invoice generation.
CRON_SECRET=replace-with-a-long-random-secret

# SMTP host used for transactional email.
SMTP_HOST=smtp.example.com

# SMTP port for the mail server.
SMTP_PORT=587

# SMTP username for authentication.
SMTP_USER=smtp-user

# SMTP password for authentication.
SMTP_PASSWORD=smtp-password

# Sender address used for outbound email.
FROM_EMAIL=Recuring <no-reply@example.com>

# Optional Razorpay key id for the payment phase.
RAZORPAY_KEY_ID=

# Optional Razorpay key secret for the payment phase.
RAZORPAY_KEY_SECRET=

# Razorpay webhook signing secret for payment event verification.
RAZORPAY_WEBHOOK_SECRET=

# Cloudflare R2 storage (S3-compatible)
# Get these from the Cloudflare dashboard under R2 > Manage API Tokens
CLOUDFLARE_R2_ENDPOINT=https://.r2.cloudflarestorage.com
S3_BUCKET=your-r2-bucket-name
S3_REGION=auto
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Optional Sentry DSN for error monitoring.
SENTRY_DSN=

# Optional local overrides used by docker-compose for the database container.
POSTGRES_DB=recuring_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional local pgAdmin login for DB management.
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin123
